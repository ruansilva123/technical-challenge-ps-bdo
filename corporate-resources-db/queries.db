CREATE DATABASE CorporateResource;

USE CorporateResource;

CREATE TABLE Countries (
	Id INT PRIMARY KEY IDENTITY(1, 1),
	Name NVARCHAR(100) NOT NULL,
	CreationDate DATETIME NOT NULL,
	UpdateDate DATETIME NOT NULL,
	IsActive BIT NOT NULL DEFAULT 1
);

CREATE TABLE States (
	Id INT PRIMARY KEY IDENTITY(1, 1),
	Name NVARCHAR(100) NOT NULL,
	CreationDate DATETIME NOT NULL,
	UpdateDate DATETIME NOT NULL,
	IsActive BIT NOT NULL DEFAULT 1
);

CREATE TABLE Cities (
	Id INT PRIMARY KEY IDENTITY(1, 1),
	Name NVARCHAR(100) NOT NULL,
	CreationDate DATETIME NOT NULL,
	UpdateDate DATETIME NOT NULL,
	IsActive BIT NOT NULL DEFAULT 1
);

CREATE TABLE Locations (
	Id INT PRIMARY KEY IDENTITY(1, 1),
	CreationDate DATETIME NOT NULL,
	UpdateDate DATETIME NOT NULL,
	IsActive BIT NOT NULL DEFAULT 1,

	CountriesId INT NOT NULL,
	StatesId INT NOT NULL,
	CitiesId INT NOT NULL,
	CONSTRAINT FKCountries FOREIGN KEY (CountriesId) REFERENCES Countries(Id),
	CONSTRAINT FKStates FOREIGN KEY (StatesId) REFERENCES States(Id),
	CONSTRAINT FKCities FOREIGN KEY (CitiesId) REFERENCES Cities(Id)
);

CREATE TABLE ResourceCategories (
	Id INT PRIMARY KEY IDENTITY(1, 1),
	Name NVARCHAR(100) NOT NULL,
	Description NVARCHAR(200), 
	CreationDate DATETIME NOT NULL,
	UpdateDate DATETIME NOT NULL,
	IsActive BIT NOT NULL DEFAULT 1
);

CREATE TABLE Resources (
	Id INT PRIMARY KEY IDENTITY(1, 1),
	Name NVARCHAR(100) NOT NULL,
	Description NVARCHAR(200), 
	CreationDate DATETIME NOT NULL,
	UpdateDate DATETIME NOT NULL,
	IsActive BIT NOT NULL DEFAULT 1,

	ResourceCategoriesId INT NOT NULL,
	LocationsId INT NOT NULL,
	CONSTRAINT FKResourceCategories FOREIGN KEY (ResourceCategoriesId) REFERENCES ResourceCategories(Id),
	CONSTRAINT FKLocatios FOREIGN KEY (LocationsId) REFERENCES Locations(Id)
);

CREATE TABLE Reservations (
	Id INT PRIMARY KEY IDENTITY(1, 1),
	StartReservation DATETIME NOT NULL,
	EndReservation DATETIME NOT NULL,
	CreationDate DATETIME NOT NULL,
	UpdateDate DATETIME NOT NULL,
	IsActive BIT NOT NULL DEFAULT 1,

	ResourcesId INT NOT NULL,
	CONSTRAINT FKResources FOREIGN KEY (ResourcesId) REFERENCES Resources(Id)
);